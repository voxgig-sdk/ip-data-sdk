        "contact": {
          "url": "https://ipapi.is/"
        },
        "description": "ipapi.is provides a comprehensive API for obtaining detailed information on IP addresses, including geolocation, hosting provider data, and detection of VPNs, proxies, and abusive behavior. The API is designed for both developers and businesses, offering a user-friendly interface with a generous free tier for basic usage.",
        "servers": [
          {
            "description": "Main API server (routed via Azure Traffic Manager)",
            "url": "https://api.ipapi.is"
          },
          {
            "description": "US East server",
            "url": "https://us.ipapi.is"
          },
          {
            "description": "Central Europe (Germany) server",
            "url": "https://de.ipapi.is"
          },
          {
            "description": "Singapore/Asia server",
            "url": "https://sg.ipapi.is"
          }
        ],
        "termsOfService": "https://ipapi.is/",
        "title": "IP Data API",
        "version": "1.0.0",
        "tagline": "Look up geolocation, ASN, hosting, VPN/proxy/Tor, and abuse signals for any IP address",
        "homepage": "https://ipapi.is/",
        "docs_url": "https://ipapi.is/",
        "license_short": "Free tier of 1,000 requests/day; paid plans for higher volume. See ipapi.is terms.",
        "license_md": "- Free plan offers 1,000 daily requests with no signup required for basic usage\n- Paid plans available; purchased credits remain valid indefinitely\n- Terms and privacy policy at https://ipapi.is/terms.html and https://ipapi.is/privacy.html\n- WHOIS-sourced data attributed to the five Regional Internet Registries",
        "about_md": "[ipapi.is](https://ipapi.is/) is an IP intelligence API that returns geolocation, network ownership, and risk signals for any IPv4 or IPv6 address. The service sources its ownership data from the five Regional Internet Registries (RIRs) via WHOIS and combines it with detection heuristics for hosting, anonymization, and abuse.\n\nWhat you get from the API:\n\n- IP metadata flags including `bogon`, `mobile`, `satellite`, and `crawler` status\n- Detection of datacenter, VPN, proxy, and Tor exit nodes\n- Company and ASN details with abuser scores, network range, and routing information\n- Geolocation including country, state, city, latitude, longitude, timezone, and local time\n- Abuse contact information (name, address, email) drawn from WHOIS records\n\nThe primary endpoint is `GET https://api.ipapi.is/?q={ip}` and responses are available in JSON, HTML, Toon, text, or CSV. Bulk lookups of up to 100 IPs per call are supported on standard plans (up to 1,000 per call on higher tiers). CORS is enabled.",
        "entity_desc": {
          "get_ip_info": "Returns the full IP intelligence record — geolocation, ASN/company, hosting and anonymization flags, and abuse signals — via `GET /?q={ip}`."
        },
        "auth": false
      },
